# Configuration de l'agent LangChain pour l'analyse politique

# OpenAI API Key (obligatoire pour utiliser l'agent IA)
# Obtenir une clé sur: https://platform.openai.com/api-keys
# Sans clé, l'app utilisera les stubs locaux (analyse déterministe)
OPENAI_API_KEY=sk-your-api-key-here

# Modèle OpenAI à utiliser (optionnel, défaut: gpt-4-turbo-preview)
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo, etc.
# OPENAI_MODEL=gpt-4-turbo-preview

# Environnement (optionnel)
NODE_ENV=development
